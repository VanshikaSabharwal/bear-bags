generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Order {
  id              String      @id @default(cuid())
  customerName    String
  email           String
  phone           String
  address         String
  city            String
  pincode         String
  paymentMethod   String
  subtotal        Int
  shipping        Int
  total           Int
  hasSubscription Boolean     @default(false)
  zohoSynced      Boolean     @default(false)
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    Int
  productName  String
  price        Int
  quantity     Int
  purchaseType String // 'subscribe' | 'oneTime'
}
